{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default desktop capability for Neon Subtitle Studio",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-is-fullscreen",
    "core:window:allow-set-fullscreen",
    "core:window:allow-set-simple-fullscreen",
    "dialog:default",
    "shell:allow-open",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "neon-engine",
          "sidecar": true
        }
      ]
    }
  ]
}
