{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Neon Subtitle Studio",
  "version": "1.0.0",
  "identifier": "com.neon.subtitle.studio",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Neon Subtitle Studio",
        "width": 1440,
        "height": 920,
        "minWidth": 980,
        "minHeight": 720
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg"],
    "externalBin": ["binaries/neon-engine"],
    "resources": {
      "../assets": "assets",
      "../engine": "engine"
    },
    "macOS": {
      "minimumSystemVersion": "11.0"
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
