#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
ROOT_DIR=""

for CANDIDATE in \
  "$SCRIPT_DIR/../.." \
  "$SCRIPT_DIR/../../.." \
  "$SCRIPT_DIR/../../../.." \
  "$(pwd)" \
  "$(pwd)/.."; do
  if [ -f "$CANDIDATE/engine/main.py" ]; then
    ROOT_DIR="$(cd "$CANDIDATE" && pwd)"
    break
  fi
done

if [ -z "$ROOT_DIR" ]; then
  echo "[NEON_ERROR] {\"code\":\"NS-SIDECAR-ROOT-NOT-FOUND\",\"stage\":\"engine_boot\",\"message\":\"Project root with engine/main.py could not be located.\"}" >&2
  exit 1
fi

export NEON_STUDIO_DATA="${NEON_STUDIO_DATA:-$ROOT_DIR/.neon-data}"
exec python3 "$ROOT_DIR/engine/main.py" --dev
